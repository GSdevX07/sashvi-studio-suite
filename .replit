modules = ["nodejs-20", "web"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd sashvi-studio-suite-main && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[userenv]

[userenv.shared]
ADMIN_EMAIL = "admin@sashvistudio.com"
VITE_SUPABASE_URL = "https://zzudwxxkwscgiakjiexz.supabase.co"
IMAGEKIT_PUBLIC_KEY = "public_7AAtMlwbYycz58Vm+ffxsNkbRy4="
IMAGEKIT_URL_ENDPOINT = "https://ik.imagekit.io/qncajau4w"
EMAIL_FROM = "Sashvi Studio <orders@sashvistudio.in>"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "cd sashvi-studio-suite-main && node .output/server/index.mjs"]
build = ["bash", "-c", "cd sashvi-studio-suite-main && npm run build"]
